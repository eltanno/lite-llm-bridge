# .env.example — COMMIT this file (placeholders only, never real secrets)
# Copy to .env (which is gitignored) and fill in real values before `docker compose up -d`.

# Gateway auth. Must start with sk-. Generate a random value, e.g.: openssl rand -hex 16
LITELLM_MASTER_KEY=sk-change-me-generate-random-value

# Ollama Cloud API key — create one at https://ollama.com/settings/keys
OLLAMA_API_KEY=ollama-your-api-key-from-settings
